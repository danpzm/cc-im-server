# 生产环境共用配置（复制为 .env.shared，部署机单独保管密钥）
# 加载：APP_ENV=prod 或 CONFIG_DIR=env/prod

REDIS_PORT=6379
REDIS_ADDR=redis.internal
REDIS_PASSWORD=change_me
REDIS_CONNECT=redis.internal:6379
REDIS_USERNAME=default

DB_DNS="host=postgres.internal user=postgres password=change_me dbname=postgres port=5432 sslmode=require TimeZone=Asia/Shanghai"

POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

TRUSTED_PROXIES=10.0.0.0/8

QUIC_DIAL_ADDRS_REDIS_KEY=quic:dial_addrs
HTTP_BASE_URLS_REDIS_KEY=http:base_urls
OSS_BASE_URLS_REDIS_KEY=oss:base_urls
MEDIA_DIAL_ADDRS_REDIS_KEY=media:dial_addrs

QUEUE_MAIN_DB=1
QUEUE_QUIC_DB=2
QUEUE_OPLOG_DB=3
QUEUE_CONCURRENCY=10

JWT_KEY=change_me_to_a_long_random_secret_in_production
ACCESS_TOKEN_EXPIRE=2h
CONNECT_TOKEN_EXPIRE=5m
# refresh 自登录起绝对过期；轮换 refresh 不会续期，仅 access 可刷新至该截止点
REFRESH_TOKEN_EXPIRE=168h
