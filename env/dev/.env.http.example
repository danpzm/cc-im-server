# 开发环境 cmd/http
HTTP_LISTEN_ADDR=:8080
HTTP_CLIENT_BASE_URL=http://localhost:8080

MAIL_USER=you@example.com
MAIL_PASSWORD=your_smtp_authorization_code
MAIL_HOST=smtp.example.com
MAIL_PORT=465
INVITE_WEB_BASE_URL=http://localhost:8080

GEOIP_DB_PATH=geodb/GeoLite2-City.mmdb
DB_AUTO_MIGRATE=true

# 桌面 IM web/ 完整性 manifest（按版本子目录，上传后无需重启 HTTP）
# 示例：data/desktop/web-manifests/0.1.0/web-manifest.json[.sig]
DESKTOP_WEB_MANIFEST_DIR=data/desktop/web-manifests
