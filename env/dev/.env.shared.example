# 开发环境共用配置（复制为 .env.shared，勿提交真实密钥）
# 加载：APP_ENV=dev（默认）或 CONFIG_DIR=env/dev

REDIS_PORT=6379
REDIS_ADDR=localhost
REDIS_PASSWORD=change_me
REDIS_CONNECT=localhost:6379
REDIS_USERNAME=default

DB_DNS="host=localhost user=postgres password=change_me dbname=postgres port=5432 sslmode=disable TimeZone=Asia/Shanghai"

POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

TRUSTED_PROXIES=127.0.0.1

QUIC_DIAL_ADDRS_REDIS_KEY=quic:dial_addrs
HTTP_BASE_URLS_REDIS_KEY=http:base_urls
OSS_BASE_URLS_REDIS_KEY=oss:base_urls
MEDIA_DIAL_ADDRS_REDIS_KEY=media:dial_addrs

QUEUE_MAIN_DB=1
QUEUE_QUIC_DB=2
QUEUE_OPLOG_DB=3
QUEUE_CONCURRENCY=10

JWT_KEY=change_me_to_a_long_random_secret
ACCESS_TOKEN_EXPIRE=2h
CONNECT_TOKEN_EXPIRE=5m
# refresh 自登录起绝对过期；轮换 refresh 不会续期，仅 access 可刷新至该截止点
REFRESH_TOKEN_EXPIRE=168h
